# ══════════════════════════════════════════════════════════════════════════════
# PharmaAssist AI - Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM API (REQUIRED) ────────────────────────────────────────────────────────
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Database Configuration (OPTIONAL) ─────────────────────────────────────────
# Only required if using database tools (order tracking, customer management)
# Leave empty to run without database features
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pharma_db
DB_USER=postgres
DB_PASS=your_database_password

# ── RAG Configuration (OPTIONAL) ──────────────────────────────────────────────
# Path to the FAQ PDF for knowledge base
# Default: rag/Pharmacy E-Commerce FAQ.pdf
PDF_PATH=rag/Pharmacy E-Commerce FAQ.pdf

# HuggingFace token (optional, only needed for private models)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Email Notifications (OPTIONAL) ────────────────────────────────────────────
# Only required if using email notification features
# For Gmail: Use App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
MAIL_SENDER=your_email@gmail.com
MAIL_APP_PASSWORD=your_app_password_here

# ── Application Environment (OPTIONAL) ────────────────────────────────────────
# Options: development, staging, production
ENV=development

# ── CORS Configuration (OPTIONAL) ─────────────────────────────────────────────
# Comma-separated list of allowed origins for API access
# Default: http://localhost:3000,http://localhost:8501
# Production: Set to your actual frontend domain(s)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501
